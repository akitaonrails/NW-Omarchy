# nw-omarchy default sxhkdrc — port of the user's Hyprland bindings.
# Reload after edits:  pkill -USR1 -x sxhkd
#
# super = Mod4 (Win key). The user file ~/.config/sxhkd/sxhkdrc is loaded
# AFTER this one and overrides on conflict.
#
# App launchers route through nw-omarchy-launch-* / -cmd-* helpers in
# ~/.local/share/nw-omarchy/bin (added to PATH by bspwmrc). These are X11
# ports of the omarchy-launch-* helpers in your hypr config — they share
# behaviour (default browser, focus-or-launch, --app= webapps, etc.) but
# use wmctrl/xdotool instead of hyprctl.

#─── apps ─────────────────────────────────────────────────────────────
# Each app binding here gets a leading `# Label` comment. nw-omarchy-launcher
# (super+space) parses these into a rofi-driven cheat-sheet picker — the
# label is what you see in the popup; the chord is shown next to it.

# Terminal
super + Return
    sh -c 'alacritty --working-directory "$(nw-omarchy-cmd-terminal-cwd)"'

# Tmux
super + alt + Return
    alacritty -e bash -c "tmux attach || tmux new -s Work"

# Browser
super + shift + Return
    nw-omarchy-launch-browser

# Browser
super + b
    nw-omarchy-launch-browser

# Browser
super + shift + b
    nw-omarchy-launch-browser

# Browser (private)
super + shift + alt + b
    nw-omarchy-launch-browser --private

# Files
super + shift + f
    nw-omarchy-launch-or-focus nautilus "nautilus --new-window"

# Files (cwd)
super + shift + alt + f
    sh -c 'nautilus --new-window "$(nw-omarchy-cmd-terminal-cwd)"'

# Editor
super + shift + n
    nw-omarchy-launch-editor

# Docker
super + shift + d
    nw-omarchy-launch-tui lazydocker

# Spotify
super + shift + m
    nw-omarchy-launch-or-focus spotify

# Signal
super + shift + g
    nw-omarchy-launch-or-focus signal-desktop

# Obsidian
super + shift + o
    nw-omarchy-launch-or-focus obsidian "obsidian --disable-gpu"

# Typora
super + shift + w
    typora

# 1Password
super + shift + slash
    1password

#─── webapp bindings (Chrome --app= windows; parity with hypr) ────────
# ChatGPT
super + shift + a
    nw-omarchy-launch-webapp "https://chatgpt.com"

# Grok
super + shift + alt + a
    nw-omarchy-launch-webapp "https://grok.com"

# Calendar
super + shift + c
    nw-omarchy-launch-webapp "https://app.hey.com/calendar/weeks/"

# Email
super + shift + e
    nw-omarchy-launch-webapp "https://app.hey.com"

# YouTube
super + shift + y
    nw-omarchy-launch-webapp "https://youtube.com/"

# WhatsApp
super + shift + alt + g
    nw-omarchy-launch-or-focus-webapp WhatsApp "https://web.whatsapp.com/"

# Google Messages
super + shift + ctrl + g
    nw-omarchy-launch-or-focus-webapp "Google Messages" "https://messages.google.com/web/conversations"

# Google Photos
super + shift + p
    nw-omarchy-launch-or-focus-webapp "Google Photos" "https://photos.google.com/"

# X.com
super + shift + x
    nw-omarchy-launch-webapp "https://x.com/"

# X.com (compose)
super + shift + alt + x
    nw-omarchy-launch-webapp "https://x.com/compose/post"

#─── menus / launcher ─────────────────────────────────────────────────
# Full app launcher: every .desktop entry on the system. Default chord
# because "type to find any app" is the most-used flow.
super + space
    rofi -show drun -show-icons

# Pinned-apps cheat-sheet: shows only apps with a custom binding (the
# entries above), each labelled with its chord. Type to filter by name.
# Useful when you want to remember "what was that chord for Spotify?"
# without leaving the keyboard.
super + shift + space
    nw-omarchy-launcher

super + alt + space
    nw-omarchy-menu

super + Escape
    nw-omarchy-menu System

super + ctrl + e
    rofi -show emoji

# Calculator (rofi-calc): result auto-copies to clipboard on Enter.
super + ctrl + c
    rofi -show calc -modi calc -no-show-match -no-sort -calc-command 'echo -n "{result}" | xclip -selection clipboard'

super + k
    nw-omarchy-menu-keybindings

# Web search (parity with omarchy walker's websearch provider)
super + slash
    nw-omarchy-launcher-websearch

#─── clipboard history (rofi-backed; CM_LAUNCHER=rofi set in bspwmrc) ──
# NOTE: omarchy's super+c / super+v / super+x universal copy/paste/cut
# bindings are NOT ported. On X11 we couldn't reliably synthesise the
# ctrl+v / ctrl+Insert chord while the user was still physically
# holding super — see docs/clipboard.md for the full story. Use the
# native ctrl+c / ctrl+v / ctrl+x in apps; super+ctrl+v opens history.
super + ctrl + v
    clipmenu

#─── window control ───────────────────────────────────────────────────
# Close window
super + w
    bspc node -c

# Toggle window split (omarchy v1: dwindle togglesplit)
super + j
    bspc node -t \~tiled

# Pseudo window
super + p
    bspc node -t \~pseudo_tiled

# Toggle window floating/tiling
super + shift + v
    bspc node -t \~floating

# Fullscreen (omarchy v2: super+f)
super + f
    bspc node -t \~fullscreen

# Fullscreen (legacy keys, kept for muscle memory)
shift + F11
    bspc node -t \~fullscreen
alt + F11
    bspc node -t \~fullscreen

#─── focus (arrow keys, Hypr parity) ──────────────────────────────────
super + Left
    bspc node -f west
super + Right
    bspc node -f east
super + Up
    bspc node -f north
super + Down
    bspc node -f south

#─── swap (Hypr SUPER+SHIFT+arrow → swapwindow) ──────────────────────
super + shift + Left
    bspc node -s west
super + shift + Right
    bspc node -s east
super + shift + Up
    bspc node -s north
super + shift + Down
    bspc node -s south

#─── workspaces (1-5, parity with omarchy waybar) ──────────────────────
super + {1-5}
    bspc desktop -f {1-5}

super + shift + {1-5}
    bspc node -d {1-5} --follow

#─── workspace cycling ────────────────────────────────────────────────
super + Tab
    bspc desktop -f next.local
super + shift + Tab
    bspc desktop -f prev.local
super + ctrl + Tab
    bspc desktop -f last

#─── alt-tab through windows on current desktop ──────────────────────
alt + Tab
    bspc node -f next.local.!hidden.window
alt + shift + Tab
    bspc node -f prev.local.!hidden.window

#─── resize (Hypr: SUPER+minus / SUPER+equal) ────────────────────────
super + minus
    bspc node -z left -100 0
super + equal
    bspc node -z right 100 0
super + shift + minus
    bspc node -z top 0 -100
super + shift + equal
    bspc node -z bottom 0 100

#─── screenshots / capture ───────────────────────────────────────────
# Screenshot (fullscreen) — bare Print fires immediately, no crosshair.
# This is the most common "I just need a screenshot now" path.
Print
    nw-omarchy-cmd-screenshot fullscreen

# Screenshot (region) — slop crosshair selection. shift indicates the
# more selective / slower path.
shift + Print
    nw-omarchy-cmd-screenshot region

# Screenrecording (omarchy: alt+Print → record menu)
alt + Print
    nw-omarchy-menu Capture

# Color picker (omarchy: super+Print → hyprpicker. We use xcolor.)
super + Print
    sh -c 'col=$(xcolor 2>/dev/null) && [ -n "$col" ] && printf "%s" "$col" | xclip -selection clipboard && notify-send -u low "Color copied" "$col"'

#─── system / aesthetics ──────────────────────────────────────────────
# Toggle workspace layout (omarchy v2 super+l)
super + l
    nw-omarchy-toggle-layout

# Lock system (omarchy v2 super+ctrl+l)
super + ctrl + l
    nw-omarchy-lock

# Toggle window gaps
super + BackSpace
    nw-omarchy-toggle-gaps

#─── notifications (dunst — parity with omarchy mako/super+comma) ────
# Dismiss last notification
super + comma
    dunstctl close

# Dismiss all notifications
super + shift + comma
    dunstctl close-all

# Toggle silencing notifications
super + ctrl + comma
    dunstctl set-paused toggle

#─── controls (per-app TUIs and toggles, omarchy super+ctrl+letter) ──
# Audio controls
super + ctrl + a
    nw-omarchy-launch-audio

# Bluetooth controls
super + ctrl + b
    nw-omarchy-launch-bluetooth

# Wifi controls
super + ctrl + w
    nw-omarchy-launch-wifi

# Activity (btop)
super + ctrl + t
    nw-omarchy-launch-tui btop

# Hardware menu
super + ctrl + h
    nw-omarchy-menu Hardware

# Share menu (omarchy super+ctrl+s)
super + ctrl + s
    nw-omarchy-menu Share

# Toggle nightlight (redshift)
super + ctrl + n
    nw-omarchy-toggle-nightlight

# Toggle locking on idle
super + ctrl + i
    nw-omarchy-toggle-idle

# Toggle laptop display
super + ctrl + Delete
    nw-omarchy-monitor-internal toggle

#─── status notifications (omarchy super+ctrl+alt+letter) ────────────
# Show time
super + ctrl + alt + t
    sh -c 'notify-send -u low "    $(date +"%A %H:%M  ·  %d %B %Y  ·  Week %V")"'

# Show battery remaining
super + ctrl + alt + b
    sh -c 'notify-send -u low "$(omarchy-battery-status 2>/dev/null || cat /sys/class/power_supply/BAT0/capacity 2>/dev/null && echo "%")"'

#─── multimedia keys ──────────────────────────────────────────────────
XF86AudioRaiseVolume
    pactl set-sink-volume @DEFAULT_SINK@ +5%
XF86AudioLowerVolume
    pactl set-sink-volume @DEFAULT_SINK@ -5%
XF86AudioMute
    pactl set-sink-mute @DEFAULT_SINK@ toggle
XF86AudioMicMute
    nw-omarchy-cmd-mic-mute

XF86MonBrightnessUp
    brightnessctl set +5%
XF86MonBrightnessDown
    brightnessctl set 5%-

XF86KbdBrightnessUp
    brightnessctl --device='*kbd_backlight*' set +1
XF86KbdBrightnessDown
    brightnessctl --device='*kbd_backlight*' set 1-

XF86AudioPlay
    playerctl play-pause
XF86AudioNext
    playerctl next
XF86AudioPrev
    playerctl previous
