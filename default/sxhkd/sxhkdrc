# nw-omarchy default sxhkdrc — port of the user's Hyprland bindings.
# Reload after edits:  pkill -USR1 -x sxhkd
#
# super = Mod4 (Win key). The user file ~/.config/sxhkd/sxhkdrc is loaded
# AFTER this one and overrides on conflict.
#
# App launchers route through nw-omarchy-launch-* / -cmd-* helpers in
# ~/.local/share/nw-omarchy/bin (added to PATH by bspwmrc). These are X11
# ports of the omarchy-launch-* helpers in your hypr config — they share
# behaviour (default browser, focus-or-launch, --app= webapps, etc.) but
# use wmctrl/xdotool instead of hyprctl.

#─── apps ─────────────────────────────────────────────────────────────
# Open terminal in the focused window's cwd if it's a terminal, else $HOME.
super + Return
    sh -c 'alacritty --working-directory "$(nw-omarchy-cmd-terminal-cwd)"'

super + alt + Return
    alacritty -e bash -c "tmux attach || tmux new -s Work"

super + shift + Return
    nw-omarchy-launch-browser

super + b
    nw-omarchy-launch-browser

super + shift + b
    nw-omarchy-launch-browser

super + shift + alt + b
    nw-omarchy-launch-browser --private

super + shift + f
    nw-omarchy-launch-or-focus nautilus "nautilus --new-window"

super + shift + alt + f
    sh -c 'nautilus --new-window "$(nw-omarchy-cmd-terminal-cwd)"'

super + shift + n
    nw-omarchy-launch-editor

super + shift + d
    nw-omarchy-launch-tui lazydocker

super + shift + m
    nw-omarchy-launch-or-focus spotify

super + shift + g
    nw-omarchy-launch-or-focus signal-desktop

super + shift + o
    nw-omarchy-launch-or-focus obsidian "obsidian --disable-gpu"

super + shift + w
    typora

super + shift + slash
    1password

#─── webapp bindings (Chrome --app= windows; parity with hypr) ────────
super + shift + a
    nw-omarchy-launch-webapp "https://chatgpt.com"

super + shift + alt + a
    nw-omarchy-launch-webapp "https://grok.com"

super + shift + c
    nw-omarchy-launch-webapp "https://app.hey.com/calendar/weeks/"

super + shift + e
    nw-omarchy-launch-webapp "https://app.hey.com"

super + shift + y
    nw-omarchy-launch-webapp "https://youtube.com/"

super + shift + alt + g
    nw-omarchy-launch-or-focus-webapp WhatsApp "https://web.whatsapp.com/"

super + shift + ctrl + g
    nw-omarchy-launch-or-focus-webapp "Google Messages" "https://messages.google.com/web/conversations"

super + shift + p
    nw-omarchy-launch-or-focus-webapp "Google Photos" "https://photos.google.com/"

super + shift + x
    nw-omarchy-launch-webapp "https://x.com/"

super + shift + alt + x
    nw-omarchy-launch-webapp "https://x.com/compose/post"

#─── menus / launcher ─────────────────────────────────────────────────
super + space
    rofi -show drun

super + ctrl + e
    rofi -show emoji

super + k
    rofi -show keys

#─── window control ───────────────────────────────────────────────────
super + w
    bspc node -c

super + j
    bspc node -t \~tiled

super + p
    bspc node -t \~pseudo_tiled

super + shift + v
    bspc node -t \~floating

shift + F11
    bspc node -t \~fullscreen

alt + F11
    bspc node -t \~fullscreen

#─── focus (arrow keys, Hypr parity) ──────────────────────────────────
super + Left
    bspc node -f west
super + Right
    bspc node -f east
super + Up
    bspc node -f north
super + Down
    bspc node -f south

#─── swap (Hypr SUPER+SHIFT+arrow → swapwindow) ──────────────────────
super + shift + Left
    bspc node -s west
super + shift + Right
    bspc node -s east
super + shift + Up
    bspc node -s north
super + shift + Down
    bspc node -s south

#─── workspaces (1-9, 0 → 10) ─────────────────────────────────────────
super + {1-9,0}
    bspc desktop -f {1-9,10}

super + shift + {1-9,0}
    bspc node -d {1-9,10} --follow

#─── workspace cycling ────────────────────────────────────────────────
super + Tab
    bspc desktop -f next.local
super + shift + Tab
    bspc desktop -f prev.local
super + ctrl + Tab
    bspc desktop -f last

#─── alt-tab through windows on current desktop ──────────────────────
alt + Tab
    bspc node -f next.local.!hidden.window
alt + shift + Tab
    bspc node -f prev.local.!hidden.window

#─── resize (Hypr: SUPER+minus / SUPER+equal) ────────────────────────
super + minus
    bspc node -z left -100 0
super + equal
    bspc node -z right 100 0
super + shift + minus
    bspc node -z top 0 -100
super + shift + equal
    bspc node -z bottom 0 100

#─── screenshots ──────────────────────────────────────────────────────
Print
    nw-omarchy-cmd-screenshot region

shift + Print
    nw-omarchy-cmd-screenshot fullscreen

alt + Print
    nw-omarchy-cmd-screenshot region

#─── system / aesthetics ──────────────────────────────────────────────
super + l
    nw-omarchy-lock

super + ctrl + l
    bspc desktop -l next

super + BackSpace
    sh -c 'g=$(bspc config -d focused window_gap); bspc config -d focused window_gap $([ "$g" -gt 0 ] && echo 0 || echo 4)'

#─── multimedia keys ──────────────────────────────────────────────────
XF86AudioRaiseVolume
    pactl set-sink-volume @DEFAULT_SINK@ +5%
XF86AudioLowerVolume
    pactl set-sink-volume @DEFAULT_SINK@ -5%
XF86AudioMute
    pactl set-sink-mute @DEFAULT_SINK@ toggle
XF86AudioMicMute
    pactl set-source-mute @DEFAULT_SOURCE@ toggle

XF86MonBrightnessUp
    brightnessctl set +5%
XF86MonBrightnessDown
    brightnessctl set 5%-

XF86KbdBrightnessUp
    brightnessctl --device='*kbd_backlight*' set +1
XF86KbdBrightnessDown
    brightnessctl --device='*kbd_backlight*' set 1-

XF86AudioPlay
    playerctl play-pause
XF86AudioNext
    playerctl next
XF86AudioPrev
    playerctl previous
