#!/bin/sh
# nw-omarchy default bspwmrc.
# This file is sourced by the user's ~/.config/bspwm/bspwmrc shim.
# Reload bspwm config (without restarting): bspc wm -r

NW_DEFAULT="$HOME/.local/share/nw-omarchy/default"

# sxhkd does NOT source .bashrc, so the omarchy + nw-omarchy bin dirs that
# .bashrc puts on PATH for interactive shells aren't visible here. Add them
# explicitly so sxhkd-spawned bindings can reach `nw-omarchy-launch-*`,
# `omarchy-cmd-*`, etc.
PATH="$HOME/.local/share/nw-omarchy/bin:$HOME/.local/share/omarchy/bin:$PATH"
export PATH

#─── input prefs (parity with omarchy hypr input.conf) ──────────────
# Faster key repeat: 250ms delay, 40 reps/sec.
command -v xset >/dev/null 2>&1 && xset r rate 250 40

# Natural-scrolling + clickfinger + disable-while-typing on every touchpad.
if command -v xinput >/dev/null 2>&1; then
    xinput list --name-only 2>/dev/null | while IFS= read -r name; do
        case "$name" in
            *[Tt]ouchpad*|*[Tt]rackpad*)
                xinput set-prop "$name" "libinput Natural Scrolling Enabled" 1     2>/dev/null || true
                xinput set-prop "$name" "libinput Tapping Enabled"           1     2>/dev/null || true
                xinput set-prop "$name" "libinput Disable While Typing Enabled" 1  2>/dev/null || true
                # Click method enum: { 0,0 } default, { 1,0 } button-areas, { 0,1 } clickfinger.
                xinput set-prop "$name" "libinput Click Method Enabled"      0 1   2>/dev/null || true
                ;;
        esac
    done
fi

#─── monitors / desktops ──────────────────────────────────────────────
# 5 workspaces — parity with omarchy waybar's persistent-workspaces.
bspc monitor -d 1 2 3 4 5

#─── window layout (Hyprland-ish: tight gaps, thin border, dwindle-feel) ──
bspc config border_width            2
bspc config window_gap              4
bspc config split_ratio             0.50
bspc config borderless_monocle      true
bspc config gapless_monocle         true
bspc config single_monocle          false
bspc config focus_follows_pointer   true
bspc config pointer_follows_focus   false
bspc config pointer_modifier        mod4
bspc config click_to_focus          button1
bspc config swallow_first_click     false

# Colors: static fallbacks first (Hyprland cyan), then overridden by the
# omarchy current-theme palette if our theme template has been rendered.
# Render path: ~/.config/omarchy/themed/bspwm-colors.conf.tpl  →  current/theme/.
bspc config focused_border_color    "#33ccff"
bspc config normal_border_color     "#595959"
bspc config presel_feedback_color   "#33ccff"
NW_THEME_BSPWM="$HOME/.config/omarchy/current/theme/bspwm-colors.conf"
[ -f "$NW_THEME_BSPWM" ] && . "$NW_THEME_BSPWM"

#─── window rules (parity with omarchy floating apps) ────────────────
bspc rule -a Pavucontrol            state=floating
bspc rule -a Blueman-manager        state=floating
bspc rule -a Nm-connection-editor   state=floating
bspc rule -a 1Password              state=floating
bspc rule -a Galculator             state=floating

# Setup TUIs launched by nw-omarchy-launch-{audio,wifi,bluetooth,about}:
# alacritty windows tagged with org.nw-omarchy.<tool> WM_CLASS. We make them
# float, centred, ~900x600 — same UX omarchy gets via a hyprland floating
# windowrule in default/hypr/looknfeel.conf.
bspc rule -a "org.nw-omarchy.wiremix"   state=floating center=on rectangle=900x600+0+0
bspc rule -a "org.nw-omarchy.impala"    state=floating center=on rectangle=900x600+0+0
bspc rule -a "org.nw-omarchy.bluetui"   state=floating center=on rectangle=900x600+0+0
bspc rule -a "org.nw-omarchy.fastfetch" state=floating center=on rectangle=900x600+0+0

#─── autostart (idempotent — kill existing, restart) ────────────────
pkill -x sxhkd              >/dev/null 2>&1; sleep 0.05
pkill -x picom              >/dev/null 2>&1; sleep 0.05
pkill -x dunst              >/dev/null 2>&1; sleep 0.05
pkill -x polybar            >/dev/null 2>&1; sleep 0.05
# libinput-gestures runs as python3, clipmenud runs as bash — comm is the
# interpreter, not the script name, so pkill -x doesn't match. Use -f.
pkill -f libinput-gestures  >/dev/null 2>&1; sleep 0.05
pkill -f /usr/bin/clipmenud >/dev/null 2>&1; sleep 0.05

# Tell clipmenu (and its picker) to use rofi instead of dmenu. CM_LAUNCHER is
# inherited by clipmenud's children (the picker), so set it once here.
export CM_LAUNCHER=rofi

# wallpaper — prefer omarchy's active theme background, then fall back.
NW_BG="$HOME/.config/omarchy/current/background"
if [ -e "$NW_BG" ]; then
    feh --no-fehbg --bg-fill "$NW_BG" &
else
    for w in "$HOME/.config/wallpaper.png" "$HOME/.config/wallpaper.jpg"; do
        [ -f "$w" ] && { feh --no-fehbg --bg-fill "$w" & break; }
    done
fi

# sxhkd: main config + extra config (later definitions win on conflict).
# NB: sxhkd's -c flag takes the MAIN config (singular). Additional config
# files are passed as POSITIONAL args. Earlier we used `-c A -c B`, which
# made B overwrite A and silently dropped every binding from A.
if [ -f "$HOME/.config/sxhkd/sxhkdrc" ]; then
    sxhkd -c "$NW_DEFAULT/sxhkd/sxhkdrc" "$HOME/.config/sxhkd/sxhkdrc" &
else
    sxhkd -c "$NW_DEFAULT/sxhkd/sxhkdrc" &
fi

# compositor (FT-Labs picom). Skip silently if not installed so a missing
# AUR package doesn't spam the X session log.
if command -v picom >/dev/null 2>&1; then
    picom --config "$HOME/.config/picom/picom.conf" -b
fi

# touchpad gestures (3-finger swipe → workspace switch, etc).
# Config: ~/.config/libinput-gestures.conf (symlinked to our default).
# Requires user in 'input' group; install/gestures.sh checks and warns.
if command -v libinput-gestures >/dev/null 2>&1; then
    libinput-gestures >/dev/null 2>&1 &
fi

# Idle timers — parity with omarchy hypridle:
#   5 min  → tte terminal-art screensaver (cancelled on activity)
#  10 min  → loginctl lock-session, which xss-lock catches and fires nw-omarchy-lock
# `--not-when-fullscreen` so video / presentations aren't interrupted.
pkill -f xidlehook >/dev/null 2>&1 || true
if command -v xidlehook >/dev/null 2>&1; then
    xidlehook \
        --not-when-fullscreen \
        --timer 300 'nw-omarchy-launch-screensaver force' \
                    'pkill -f org.nw-omarchy.screensaver' \
        --timer 600 'loginctl lock-session' \
                    '' \
        >/dev/null 2>&1 &
fi

# clipboard history daemon (clipnotify-based; serves the super+ctrl+v picker).
if command -v clipmenud >/dev/null 2>&1; then
    clipmenud >/dev/null 2>&1 &
fi

# Dunst theme-watcher: signals dunst to restart whenever omarchy-theme-set
# rewrites ~/.config/omarchy/current/theme.name. Lets notifications repaint
# on theme change without touching the user's omarchy theme-set hook.
pkill -f nw-omarchy-dunst-watch >/dev/null 2>&1 || true
if command -v nw-omarchy-dunst-watch >/dev/null 2>&1; then
    nw-omarchy-dunst-watch >/dev/null 2>&1 &
fi

# Low-battery notifier — reuses omarchy's existing systemd user timer
# (~/.config/systemd/user/omarchy-battery-monitor.timer). Idempotent: start
# is a no-op if already running. systemctl --user gracefully no-ops if the
# unit file isn't present (e.g. desktop with no battery).
systemctl --user start omarchy-battery-monitor.timer >/dev/null 2>&1 || true

# notifications
dunst &

# bar
"$HOME/.config/polybar/launch.sh" &

# screen locking on suspend / idle (relies on logind + xss-lock)
xss-lock --transfer-sleep-lock -- nw-omarchy-lock &

# systray helpers
nm-applet --indicator   >/dev/null 2>&1 &
blueman-applet          >/dev/null 2>&1 &
pasystray               >/dev/null 2>&1 &
