#!/usr/bin/env bash
# nw-omarchy-menu — 1:1 port of omarchy-menu for the bspwm/X11 stack.
# Driver: rofi -dmenu (instead of walker --dmenu). Every leaf maps to a
# helper; we use the omarchy-* helpers when they're cross-stack and our
# nw-omarchy-* equivalents when omarchy's are hyprctl-coupled.
#
# Bound to: super + alt + space  (top-level menu)
#           super + escape         (jump to System submenu)
#
# A user override file at ~/.config/nw-omarchy/menu.sh (if present) is
# sourced at the bottom — same extension hook omarchy-menu offers.

export PATH="$HOME/.local/share/nw-omarchy/bin:$HOME/.local/share/omarchy/bin:$PATH"

BACK_TO_EXIT=false

back_to() {
    local parent_menu="$1"
    if [[ $BACK_TO_EXIT == "true" ]]; then exit 0
    elif [[ -n $parent_menu ]]; then "$parent_menu"
    else show_main_menu; fi
}

toggle_existing_menu() {
    if pgrep -f 'rofi -dmenu .*nw-omarchy-menu' >/dev/null; then
        pkill -f 'rofi -dmenu .*nw-omarchy-menu' 2>/dev/null || true
        exit 0
    fi
}

# Drive the picker. Same surface as omarchy-menu's `menu()` — rofi reads
# newline-separated entries on stdin and emits the chosen line on stdout.
menu() {
    local prompt="$1" options="$2" extra="${3:-}" preselect="${4:-}"
    local args=(-dmenu -i -no-fixed-num-lines -p "${prompt}…")
    [ -n "$extra" ] && read -r -a x <<<"$extra" && args+=("${x[@]}")
    if [ -n "$preselect" ]; then
        local idx
        idx=$(echo -e "$options" | grep -nxF "$preselect" | head -1 | cut -d: -f1)
        [ -n "$idx" ] && args+=(-selected-row "$((idx - 1))")
    fi
    args+=(-theme-str "window { width: 600px; } listview { lines: 12; } * { font: \"JetBrainsMono Nerd Font Mono 18\"; }")
    echo -e "$options" | rofi "${args[@]}"
}

terminal()         { setsid alacritty --class org.nw-omarchy.terminal "$@" >/dev/null 2>&1 & }
present_terminal() { nw-omarchy-launch-floating-terminal "$@"; }
open_in_editor()   { notify-send -u low "Editing config file" "$1"; nw-omarchy-launch-editor "$1"; }
install()          { present_terminal "echo 'Installing $1...'; omarchy-pkg-add $2"; }
install_and_launch() { present_terminal "echo 'Installing $1...'; omarchy-pkg-add $2 && setsid gtk-launch $3"; }
install_font()     { present_terminal "echo 'Installing $1...'; omarchy-pkg-add $2 && sleep 2 && omarchy-font-set '$3'"; }
install_terminal_pkg() { present_terminal "omarchy-install-terminal $1"; }
aur_install()      { present_terminal "echo 'Installing $1 from AUR...'; omarchy-pkg-aur-add $2"; }
aur_install_and_launch() { present_terminal "echo 'Installing $1 from AUR...'; omarchy-pkg-aur-add $2 && setsid gtk-launch $3"; }

#─── Learn ─────────────────────────────────────────────────────────────
show_learn_menu() {
    case $(menu "Learn" "  Keybindings\n  Omarchy\n  Hyprland\n󰣇  Arch\n  Neovim\n󱆃  Bash") in
        *Keybindings*) nw-omarchy-menu-keybindings ;;
        *Omarchy*)   nw-omarchy-launch-webapp "https://learn.omacom.io/2/the-omarchy-manual" ;;
        *Hyprland*)  nw-omarchy-launch-webapp "https://wiki.hypr.land/" ;;
        *Arch*)      nw-omarchy-launch-webapp "https://wiki.archlinux.org/title/Main_page" ;;
        *Bash*)      nw-omarchy-launch-webapp "https://devhints.io/bash" ;;
        *Neovim*)    nw-omarchy-launch-webapp "https://www.lazyvim.org/keymaps" ;;
        *) show_main_menu ;;
    esac
}

#─── Trigger ───────────────────────────────────────────────────────────
show_trigger_menu() {
    case $(menu "Trigger" "  Capture\n  Share\n󰔎  Toggle\n  Hardware") in
        *Capture*)  show_capture_menu ;;
        *Share*)    show_share_menu ;;
        *Toggle*)   show_toggle_menu ;;
        *Hardware*) show_hardware_menu ;;
        *) show_main_menu ;;
    esac
}

show_capture_menu() {
    case $(menu "Capture" "  Screenshot\n  Screenrecord\n󰃉  Color") in
        *Screenshot*)   nw-omarchy-cmd-screenshot region ;;
        *Screenrecord*) show_screenrecord_menu ;;
        *Color*)
            if command -v xcolor >/dev/null 2>&1; then
                xcolor -s clipboard
                notify-send -u low "󰃉  Color copied to clipboard"
            else
                notify-send -u critical "Color picker needs xcolor (yay -S xcolor)"
            fi
            ;;
        *) back_to show_trigger_menu ;;
    esac
}

get_webcam_list() {
    command -v v4l2-ctl >/dev/null || return 0
    v4l2-ctl --list-devices 2>/dev/null | while IFS= read -r line; do
        if [[ $line != $'\t'* && -n $line ]]; then
            local name="$line"
            IFS= read -r device || break
            device=$(echo "$device" | tr -d '\t' | head -1)
            [[ -n $device ]] && echo "$device  $name"
        fi
    done
}

show_webcam_select_menu() {
    local devices count
    devices=$(get_webcam_list)
    count=$(echo "$devices" | grep -c . 2>/dev/null || echo 0)
    if [[ -z $devices ]] || ((count == 0)); then
        notify-send "No webcam devices found" -u critical -t 3000
        return 1
    fi
    if ((count == 1)); then echo "$devices" | awk '{print $1}'
    else menu "Select Webcam" "$devices" | awk '{print $1}'
    fi
}

show_screenrecord_menu() {
    nw-omarchy-cmd-screenrecord --stop-recording && exit 0
    case $(menu "Screenrecord" "  With no audio\n  With desktop audio\n  With desktop + microphone audio\n  With desktop + microphone audio + webcam") in
        *"With no audio")                                          nw-omarchy-cmd-screenrecord ;;
        *"With desktop audio")                                      nw-omarchy-cmd-screenrecord --with-desktop-audio ;;
        *"With desktop + microphone audio")                         nw-omarchy-cmd-screenrecord --with-desktop-audio --with-microphone-audio ;;
        *"With desktop + microphone audio + webcam")
            local device; device=$(show_webcam_select_menu) || { back_to show_capture_menu; return; }
            nw-omarchy-cmd-screenrecord --with-desktop-audio --with-microphone-audio --with-webcam --webcam-device="$device"
            ;;
        *) back_to show_capture_menu ;;
    esac
}

show_share_menu() {
    case $(menu "Share" "  Clipboard\n  File \n  Folder") in
        *Clipboard*) omarchy-cmd-share clipboard ;;
        *File*)      terminal -e bash -c "omarchy-cmd-share file" ;;
        *Folder*)    terminal -e bash -c "omarchy-cmd-share folder" ;;
        *) back_to show_trigger_menu ;;
    esac
}

show_toggle_menu() {
    local options="󱄄  Screensaver\n󰔎  Nightlight\n󱫖  Idle Lock\n󰍜  Top Bar\n󱂬  Workspace Layout\n  Window Gaps"
    case $(menu "Toggle" "$options") in
        *Screensaver*) nw-omarchy-toggle-screensaver ;;
        *Nightlight*)  nw-omarchy-toggle-nightlight ;;
        *Idle*)        nw-omarchy-toggle-idle ;;
        *Bar*)         nw-omarchy-toggle-bar ;;
        *Layout*)      nw-omarchy-toggle-layout ;;
        *Gaps*)        nw-omarchy-toggle-gaps ;;
        *) back_to show_trigger_menu ;;
    esac
}

show_hardware_menu() {
    local options="󰛧  Laptop Display"
    if command -v omarchy-hw-hybrid-gpu >/dev/null && omarchy-hw-hybrid-gpu; then
        options="$options\n  Hybrid GPU"
    fi
    options="$options\n󰟸  Touchpad\n󰍹  Display Scaling"
    case $(menu "Hardware" "$options") in
        *Laptop*)      nw-omarchy-monitor-internal toggle ;;
        *Touchpad*)    nw-omarchy-toggle-touchpad ;;
        *Scaling*)     nw-omarchy-cycle-scaling ;;
        *"Hybrid GPU"*) present_terminal omarchy-toggle-hybrid-gpu ;;
        *) back_to show_trigger_menu ;;
    esac
}

#─── Style ─────────────────────────────────────────────────────────────
show_style_menu() {
    case $(menu "Style" "󰸌  Theme\n  Font\n  Background\n  Compositor\n󱄄  Screensaver\n  About") in
        *Theme*)       show_theme_menu ;;
        *Font*)        show_font_menu ;;
        *Background*)  show_background_menu ;;
        *Compositor*)  open_in_editor "$HOME/.config/picom/picom.conf" ;;
        *Screensaver*) open_in_editor "$HOME/.config/omarchy/branding/screensaver.txt" ;;
        *About*)       open_in_editor "$HOME/.config/omarchy/branding/about.txt" ;;
        *) show_main_menu ;;
    esac
}

# Helpers for dynamic-content menus: prepend a fixed icon to every line so
# every submenu has a consistent leading-icon column for alignment, then
# strip the icon back off before passing the value to the action.
prefix_icon() { local icon="$1"; sed "s/^/${icon}  /"; }
strip_icon()  { sed -E 's/^[^[:space:]]+[[:space:]]+//'; }

show_theme_menu() {
    local current options choice theme
    current=$(cat "$HOME/.config/omarchy/current/theme.name" 2>/dev/null || echo "")
    options=$(omarchy-theme-list 2>/dev/null | prefix_icon "󰸌")
    choice=$(menu "Theme" "$options" "" "󰸌  $current")
    [ -z "$choice" ] && { back_to show_style_menu; return; }
    theme=$(printf '%s\n' "$choice" | strip_icon)
    [ "$theme" != "$current" ] && omarchy-theme-set "$theme"
}

show_background_menu() {
    local theme_dir bgs choice bg
    theme_dir="$HOME/.config/omarchy/current/theme/backgrounds"
    [ -d "$theme_dir" ] || { notify-send -u low "No backgrounds in current theme"; return; }
    bgs=$(ls "$theme_dir"/*.{jpg,png,jpeg,webp} 2>/dev/null | xargs -I{} basename {} | prefix_icon "")
    [ -z "$bgs" ] && { notify-send -u low "No backgrounds found"; return; }
    choice=$(menu "Background" "$bgs")
    [ -z "$choice" ] && { back_to show_style_menu; return; }
    bg=$(printf '%s\n' "$choice" | strip_icon)
    nw-omarchy-bg-set "$theme_dir/$bg"
}

show_font_menu() {
    local current options choice font
    current=$(omarchy-font-current 2>/dev/null || echo "")
    options=$(omarchy-font-list 2>/dev/null | prefix_icon "")
    choice=$(menu "Font" "$options" "" "  $current")
    [ -z "$choice" ] && { back_to show_style_menu; return; }
    font=$(printf '%s\n' "$choice" | strip_icon)
    omarchy-font-set "$font"
}

#─── Setup ─────────────────────────────────────────────────────────────
show_setup_menu() {
    local options="  Audio\n  Wifi\n󰂯  Bluetooth\n󱐋  Power Profile\n  System Sleep\n󰍹  Monitors\n  Keybindings\n  Input\n󰱔  DNS\n  Security\n  Config"
    case $(menu "Setup" "$options") in
        *Audio*)       nw-omarchy-launch-audio ;;
        *Wifi*)        nw-omarchy-launch-wifi ;;
        *Bluetooth*)   nw-omarchy-launch-bluetooth ;;
        *Power*)       show_setup_power_menu ;;
        *System*)      show_setup_system_menu ;;
        *Monitors*)    open_in_editor "$HOME/.config/bspwm/bspwmrc" ;;
        *Keybindings*) open_in_editor "$HOME/.config/sxhkd/sxhkdrc" ;;
        *Input*)       open_in_editor "$HOME/.config/bspwm/bspwmrc" ;;
        *DNS*)         present_terminal omarchy-setup-dns ;;
        *Security*)    show_setup_security_menu ;;
        *Config*)      show_setup_config_menu ;;
        *) show_main_menu ;;
    esac
}

show_setup_power_menu() {
    local cur options choice profile
    cur=$(powerprofilesctl get 2>/dev/null || echo "")
    options=$(omarchy-powerprofiles-list 2>/dev/null | prefix_icon "󱐋")
    choice=$(menu "Power Profile" "$options" "" "󱐋  $cur")
    [[ -z $choice ]] && { back_to show_setup_menu; return; }
    profile=$(printf '%s\n' "$choice" | strip_icon)
    powerprofilesctl set "$profile"
}

show_setup_security_menu() {
    case $(menu "Security" "󰈷  Fingerprint\n  Fido2") in
        *Fingerprint*) present_terminal omarchy-setup-fingerprint ;;
        *Fido2*)       present_terminal omarchy-setup-fido2 ;;
        *) show_setup_menu ;;
    esac
}

show_setup_config_menu() {
    case $(menu "Config" "  Defaults\n  Bspwm\n  Sxhkd\n  Picom\n  Polybar\n  Rofi\n  Dunst\n  XCompose") in
        *Defaults*) open_in_editor "$HOME/.config/uwsm/default" ;;
        *Bspwm*)    open_in_editor "$HOME/.config/bspwm/bspwmrc" && nw-omarchy-restart-bspwm ;;
        *Sxhkd*)    open_in_editor "$HOME/.config/sxhkd/sxhkdrc" && nw-omarchy-restart-sxhkd ;;
        *Picom*)    open_in_editor "$HOME/.config/picom/picom.conf" && nw-omarchy-restart-picom ;;
        *Polybar*)  open_in_editor "$HOME/.config/polybar/launch.sh" && nw-omarchy-restart-polybar ;;
        *Rofi*)     open_in_editor "$HOME/.config/rofi/config.rasi" ;;
        *Dunst*)    open_in_editor "$HOME/.config/dunst/dunstrc" && nw-omarchy-restart-dunst ;;
        *XCompose*) open_in_editor "$HOME/.XCompose" ;;
        *) show_setup_menu ;;
    esac
}

show_setup_system_menu() {
    local options=""
    if omarchy-toggle-enabled suspend-off; then options="$options󰒲  Enable Suspend"
    else options="$options󰒲  Disable Suspend"; fi
    if command -v omarchy-hibernation-available >/dev/null && omarchy-hibernation-available; then
        options="$options\n󰤁  Disable Hibernate"
    else
        options="$options\n󰤁  Enable Hibernate"
    fi
    case $(menu "System" "$options") in
        *Suspend*)             omarchy-toggle-suspend ;;
        *"Enable Hibernate"*)  present_terminal omarchy-hibernation-setup ;;
        *"Disable Hibernate"*) present_terminal omarchy-hibernation-remove ;;
        *) show_setup_menu ;;
    esac
}

