#!/usr/bin/env bash
# Synthesise an X11 key sequence reliably, even while the user is still
# physically holding the modifier that triggered the sxhkd binding.
#
# Why this exists: `xdotool key --clearmodifiers` is supposed to release
# all currently-held modifiers, send the key sequence, then restore them.
# In practice, when sxhkd fires a binding mid-press, the X server's
# modifier state can be stale (the grab consumes the event but super is
# still physically down), and xdotool's --clearmodifiers occasionally
# fails to clear the modifier — the synthetic ctrl+v ends up reaching the
# focused app as super+ctrl+v, which most apps don't bind to paste.
#
# Workaround: explicitly issue keyup events for Super_L + Super_R BEFORE
# the synthesis. That guarantees the X server's keyboard state has
# super = up by the time the synthetic ctrl+v lands.
#
# NB: keysym names are case-sensitive — `super_l` is silently rejected
# by xdotool ("No such key name") and the keyup is a no-op. Use the
# canonical `Super_L` / `Super_R`.
#
# Usage: nw-omarchy-send-key <chord>     (same chord syntax as `xdotool key`)
#
# Examples:
#   nw-omarchy-send-key ctrl+Insert
#   nw-omarchy-send-key ctrl+v
#   nw-omarchy-send-key ctrl+x

set -e
xdotool keyup Super_L Super_R 2>/dev/null || true
xdotool key --clearmodifiers "$@"
