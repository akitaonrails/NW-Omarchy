#!/usr/bin/env bash
# X11 screenshot helper, parity surface with omarchy-cmd-screenshot but built
# on maim + slop + xclip. Saves to $OMARCHY_SCREENSHOT_DIR / $XDG_PICTURES_DIR
# / ~/Pictures.
#
# Usage:  nw-omarchy-cmd-screenshot [region|fullscreen|smart]
#
# `smart` and `region` both use a maim+slop interactive selection. We don't
# emulate the Wayland version's auto-snap-to-window-when-tiny logic — bspwm
# users can just press the binding twice if they misclick.

set -e

# Toggle: a running slop indicates a previous invocation is still selecting;
# kill it and exit so the same binding cancels the action.
if pgrep -x slop >/dev/null; then
    pkill -x slop || true
    exit 0
fi

[ -f ~/.config/user-dirs.dirs ] && . ~/.config/user-dirs.dirs
PICTURES="${XDG_PICTURES_DIR:-$HOME/Pictures}"
OUTPUT_DIR="${OMARCHY_SCREENSHOT_DIR:-$PICTURES/Screenshots}"
mkdir -p "$OUTPUT_DIR"

MODE="${1:-smart}"

FILENAME="screenshot-$(date +'%Y-%m-%d_%H-%M-%S').png"
FILEPATH="$OUTPUT_DIR/$FILENAME"

case "$MODE" in
    region|smart)
        # `maim --select` cancels on Esc with non-zero exit; treat as no-op.
        maim --select "$FILEPATH" 2>/dev/null || exit 0
        ;;
    fullscreen)
        maim "$FILEPATH"
        ;;
    delayed-fullscreen)
        # 3-second countdown before firing. Use case: capturing a menu
        # / rofi / dropdown that has the keyboard grab — you press this
        # chord first, get 3 seconds to open the thing you want to
        # screenshot, then maim fires regardless of who has the
        # keyboard. notify-send shows the countdown so you don't have
        # to guess the timing.
        notify-send -u low "Screenshot in 3s…" \
            "Open the menu / rofi you want to capture now." -t 2800
        sleep 3
        maim "$FILEPATH"
        ;;
    *)
        echo "unknown mode: $MODE (region|fullscreen|delayed-fullscreen|smart)" >&2
        exit 1
        ;;
esac

[ -s "$FILEPATH" ] || exit 0

# Copy to clipboard for paste-into-chat-app workflows.
if command -v xclip >/dev/null 2>&1; then
    xclip -selection clipboard -t image/png -i <"$FILEPATH"
fi

if command -v notify-send >/dev/null 2>&1; then
    # Background subshell so the screenshot script exits immediately;
    # notify-send --wait blocks until the notification is dismissed
    # (returning the action ID on stdout) which we use to xdg-open the
    # file when the user left-clicks the toast. Middle-click opens the
    # dunst context menu where "Show in folder" is available too.
    (
        action=$(notify-send -a 'screenshot' \
            --action='default=Open' \
            --action='folder=Show in folder' \
            -t 4000 -i "$FILEPATH" \
            'Screenshot saved' "$FILEPATH" 2>/dev/null)
        case "$action" in
            default) xdg-open "$FILEPATH" >/dev/null 2>&1 ;;
            folder)  xdg-open "$(dirname "$FILEPATH")" >/dev/null 2>&1 ;;
        esac
    ) </dev/null >/dev/null 2>&1 &
    disown
fi
