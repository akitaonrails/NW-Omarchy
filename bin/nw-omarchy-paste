#!/usr/bin/env bash
# nw-omarchy-paste — type CLIPBOARD content into the focused window.
#
# Why not synthesise ctrl+v?  Because the user is physically holding
# super at the moment sxhkd fires our binding. xdotool's keyup Super_L /
# --clearmodifiers do release super at the X server's view, but the
# kernel (evdev) immediately re-asserts super-down because the physical
# key is still pressed. Result: the synthetic ctrl+v arrives at the
# focused app as super+ctrl+v, which most apps don't bind to anything.
# (Verified live in alacritty: keyup Super_L Super_R + xdotool key
# ctrl+v with --clearmodifiers, both exit 0, but no paste.)
#
# `xdotool type` sends each character as a KeyPress event with the
# event's state field set to 0 — i.e. "no modifiers held" in the event
# itself, regardless of what evdev says. Apps that read the event's
# state field (the vast majority — browsers, GTK, Qt, Electron, rofi,
# alacritty, …) accept the chars as plain input.
#
# Trade-off: rich-text clipboard pastes as plaintext (same as omarchy's
# shift+Insert path on Wayland). Newlines in clipboard get typed as
# Return — in a terminal that means lines execute. Use clipmenu
# (super+ctrl+v) for multi-line content into a terminal, or use the
# terminal's native ctrl+shift+v.

set -e

content=$(xclip -selection clipboard -o 2>/dev/null) || exit 0
[ -n "$content" ] || exit 0

# Let the user release super before we start typing — otherwise the first
# synthetic char might race the still-held super and pick it up. 50ms is
# imperceptible; 0ms occasionally swallows the first char.
sleep 0.05

xdotool type --clearmodifiers --delay 0 -- "$content"
