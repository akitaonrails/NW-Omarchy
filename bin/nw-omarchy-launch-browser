#!/usr/bin/env bash
# X11 port of omarchy-launch-browser. Resolves the user's default browser via
# xdg-settings, translates `--private` to the browser-specific incognito flag,
# and execs it via setsid (so it survives sxhkd's controlling terminal).

set -e

default_browser=$(xdg-settings get default-web-browser 2>/dev/null || true)
[ -z "$default_browser" ] && default_browser="chromium.desktop"

browser_exec=$(sed -n 's/^Exec=\([^ ]*\).*/\1/p' \
    {"$HOME"/.local,"$HOME"/.nix-profile,/usr}/share/applications/"$default_browser" \
    2>/dev/null | head -1)

[ -z "$browser_exec" ] && { echo "could not resolve $default_browser" >&2; exit 1; }

# Determine the per-browser incognito/private flag.
if "$browser_exec" --help 2>/dev/null | grep -qE 'MOZ_LOG|firefox|private-window'; then
    private_flag="--private-window"
elif [[ $browser_exec == *edge* ]]; then
    private_flag="--inprivate"
else
    private_flag="--incognito"
fi

# Translate any literal `--private` arg to the resolved per-browser flag.
args=()
for a in "$@"; do
    [ "$a" = "--private" ] && a="$private_flag"
    args+=("$a")
done

# Omarchy ships ~/.config/{brave,chromium}-flags.conf with
# --ozone-platform=wayland hardcoded. Inside an X11 session that kills the
# browser at startup ("Failed to connect to Wayland display"). Chromium's
# CLI parser uses last-wins for --ozone-platform, so appending x11 here
# overrides the conf-file flag without us having to touch the conf file
# (which is correct for Hyprland — leave it alone).
if [ "${XDG_SESSION_TYPE:-}" = "x11" ] && [[ "$browser_exec" =~ (brave|chromium|chrome|edge|opera|vivaldi|helium) ]]; then
    args=(--ozone-platform=x11 "${args[@]}")
fi

exec setsid "$browser_exec" "${args[@]}"
