#!/usr/bin/env bash
# nw-omarchy-menu-keybindings — sxhkd analog of omarchy-menu-keybindings.
# Parses the active sxhkdrc files and shows them in rofi for search/lookup.
# Each row: "<chord>   →   <description>   [<section>]"
#
# Sources, in order (later overrides earlier — same precedence sxhkd uses):
#   ~/.local/share/nw-omarchy/default/sxhkd/sxhkdrc
#   ~/.config/sxhkd/sxhkdrc
#
# For each chord we render the immediately-preceding `#` comment line as the
# description (matches how omarchy-menu-keybindings shows hyprctl's `bindd =`
# description field). When no comment is present we fall back to the
# command line itself.

set -euo pipefail

NW_OMARCHY_PATH="${NW_OMARCHY_PATH:-$HOME/.local/share/nw-omarchy}"
SOURCES=(
    "$NW_OMARCHY_PATH/default/sxhkd/sxhkdrc"
    "$HOME/.config/sxhkd/sxhkdrc"
)

# Parse one sxhkdrc, emit "chord<TAB>desc-or-cmd<TAB>section" lines.
#
# State machine:
#   section header  (#─── name ───) →  flush pending, update section, reset
#   empty line                       →  flush pending, reset chord/cmd/desc
#   plain comment (#…)               →  remember as the description for the
#                                       next chord we see
#   chord (non-whitespace)           →  flush pending, start new chord (with
#                                       the remembered desc attached)
#   indented (whitespace+)           →  accumulate as cmd
parse() {
    local file="$1"
    [ -f "$file" ] || return 0
    awk '
        function flush() {
            if (chord != "" && cmd != "") {
                label = (desc != "" ? desc : cmd)
                print chord "\t" label "\t" section
            }
            chord = ""; cmd = ""; desc = ""
        }
        BEGIN { section = ""; chord = ""; cmd = ""; desc = "" }

        # Section heading: lines like "#─── apps ─────"
        /^#─.*─*$/ {
            flush()
            s = $0
            sub(/^#─+ */, "", s)
            sub(/ *─+ *$/, "", s)
            section = s
            next
        }

        /^[[:space:]]*$/ {
            flush()
            next
        }

        # Plain comment (non-section). Treat as description for the next
        # chord. Multi-line comments collapse with " · " separators.
        /^[[:space:]]*#/ {
            line = $0
            sub(/^[[:space:]]*#[[:space:]]*/, "", line)
            if (line != "") {
                desc = (desc != "" ? desc " · " line : line)
            }
            next
        }

        # Chord (non-whitespace at column 1, not a comment)
        /^[^[:space:]]/ {
            flush()
            chord = $0
            cmd = ""
            next
        }

        # Indented = command body
        /^[[:space:]]+/ {
            line = $0
            sub(/^[[:space:]]+/, "", line)
            cmd = (cmd == "" ? line : cmd " ; " line)
            next
        }

        END { flush() }
    ' "$file"
}

# De-dup by chord (later sources win — sxhkd's own rule).
declare -A SEEN
LINES=()
for ((i=${#SOURCES[@]}-1; i>=0; i--)); do
    while IFS=$'\t' read -r chord label sect; do
        [ -z "$chord" ] && continue
        if [ -z "${SEEN[$chord]:-}" ]; then
            SEEN[$chord]=1
            LINES+=("$chord"$'\t'"$label"$'\t'"$sect")
        fi
    done < <(parse "${SOURCES[$i]}")
done

# Format for display. NB: the local variable is `output` — `DISPLAY` would
# shadow the X11 env variable and rofi would inherit the rendered list as
# its display address, silently failing to connect. (This was the bug
# that made super+K silently no-op for ages.)
output=""
for line in "${LINES[@]}"; do
    IFS=$'\t' read -r chord label sect <<<"$line"
    [ "${#label}" -gt 70 ] && label="${label:0:67}…"
    if [ -n "$sect" ]; then
        printf -v row '%-30s  →  %s    [%s]' "$chord" "$label" "$sect"
    else
        printf -v row '%-30s  →  %s' "$chord" "$label"
    fi
    output+="$row"$'\n'
done

[ -z "$output" ] && { notify-send -u low "No bindings found in sxhkdrc"; exit 0; }

echo -n "$output" | rofi -dmenu -i -p "Keybindings…" \
    -theme-str 'window { width: 1100px; } listview { lines: 16; } * { font: "JetBrainsMono Nerd Font Mono 16"; }' \
    -no-fixed-num-lines \
    >/dev/null
